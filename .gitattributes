# RadFlow — нормалізація закінчень рядків.
# Зберігаємо LF у репозиторії на всіх платформах, щоб уникнути
# постійних CRLF↔LF відмінностей між Windows та Linux/CI (Vercel).

# За замовчуванням: текст визначається автоматично, у робочому дереві — LF.
* text=auto eol=lf

# Явні текстові типи проєкту (LF).
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.env   text eol=lf

# Бінарні файли — без конвертації.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
