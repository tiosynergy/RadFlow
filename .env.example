# ============================================================
#  RadFlow — пример переменных окружения
#  Скопируйте этот файл в .env.local и впишите реальные значения.
#  .env.local НЕ попадает в GitHub (см. .gitignore).
#  Эти же значения позже добавьте в Vercel → Settings → Environment Variables.
# ============================================================

# ----- Supabase (база данных + авторизация + файлы) -----
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Серверный ключ (секретный, НЕ публичный) — только для серверного кода
SUPABASE_SERVICE_ROLE_KEY=

# ----- AI (пересчёт очереди / парсинг прайса) -----
# Дешёвая модель достаточно. Нужен один из двух.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ----- n8n Cloud (автоматизации) -----
# Секретный адрес webhook сценария Incident Rescheduling
N8N_WEBHOOK_URL=

# ----- Email (Resend) -----
RESEND_API_KEY=

# ----- Мониторинг (Sentry) — опционально -----
SENTRY_DSN=
